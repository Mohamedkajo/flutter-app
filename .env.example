# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://cargo:cargo_secret@localhost:5432/cargo
POSTGRES_DB=cargo
POSTGRES_USER=cargo
POSTGRES_PASSWORD=cargo_secret

# ─── Auth ────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_random_64_char_string_in_production

# ─── API Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Docker Compose ──────────────────────────────────────────────
