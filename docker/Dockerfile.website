FROM node:20-alpine AS builder
WORKDIR /app
RUN npm install -g pnpm

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY lib ./lib
COPY artifacts/website ./artifacts/website

RUN pnpm install --frozen-lockfile
RUN pnpm --filter @workspace/website run build

FROM nginx:alpine
COPY --from=builder /app/artifacts/website/dist /usr/share/nginx/html
COPY docker/nginx-spa.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
